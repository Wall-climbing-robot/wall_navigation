<?xml version="1.0"?>
<sdf version="1.7">

    <xmacro_include uri="model://mid360/model.sdf.xmacro" />

    <!-- 底盘离地高度（卷尺量底盘底板到地面距离，单位米） -->
    <xmacro_define_value name="chassis_height" value="0.03" />

    <model name="cleaner_robot">

        <pose>0 0 0.15 -0.262 0 0</pose>

        <!-- base_footprint：地面投影点，Nav2 的根帧 -->
        <link name="base_footprint"/>

        <!-- chassis：底盘本体，在 base_footprint 上方 chassis_height 处 -->
        <link name="chassis"/>
        <joint name="base_footprint_joint" type="fixed">
            <parent>base_footprint</parent>
            <child>chassis</child>
            <pose>0 0 ${chassis_height} 0 0 0</pose>
        </joint>

        <!--
            gimbal_yaw：虚拟帧，位置与 chassis 完全重合（零偏移）
            为什么要保留：fake_vel_transform 节点以 gimbal_yaw 为父帧，
            动态发布 gimbal_yaw → gimbal_yaw_fake 的 TF（带旋转）。
            不要在这里定义 gimbal_yaw_fake，否则会和 fake_vel_transform 冲突！
        -->
        <link name="gimbal_yaw"/>
        <joint name="gimbal_yaw_joint" type="fixed">
            <parent>chassis</parent>
            <child>gimbal_yaw</child>
            <pose>0 0 0 0 0 0</pose>
        </joint>

        <!--
            mid360 雷达安装位置，6 个数字含义：
            前后(m)  左右(m)  高度(m)  roll  pitch  yaw
            pitch 向前低头为负，例如 30°= -0.524，45°= -0.785

            用卷尺量好后替换下面的数字：
              第1个数：雷达中心距底盘前后中心的距离（向前为正）
              第2个数：雷达中心距底盘左右中心的距离（向左为正，居中填0）
              第3个数：雷达中心距底盘底面的高度
              第5个数：pitch 角，斜装向前低头填负数
        -->
        <xmacro_block
            name="livox"
            prefix="front_"
            parent="chassis"
            pose="0.10 -0.045 0.20 0.0 -0.332 0.0"
            update_rate="10"
            samples="1875"/>

    </model>
</sdf>
